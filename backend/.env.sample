PORT="PORT_NUMBER_HERE"

MONGODB_URI="yourMongoDbUriHere"

JWT_SECRET_KEY="jwtSecretKeyHere"

GEMINI_API_KEY="EnterYourGeminiApiKeyHere"
# Email Configuration (Gmail SMTP)
GMAIL_USER="EnterYourEmailHere"
GMAIL_APP_PASSWORD="EnterYourAppPasswordHere"

# Email Configuration (Industry-standard SMTP, preferred)
SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_USER="smtp_user"
SMTP_PASS="smtp_password"
EMAIL_FROM="Hospital Platform <no-reply@example.com>"
DAILY_SUMMARY_CRON="0 8 * * *"
DAILY_SUMMARY_TIMEZONE="UTC"

# Node Environment
NODE_ENV="development"

# Stripe Configuration (Test Keys)
STRIPE_SECRET_KEY="sk_test_your_stripe_secret_key"
STRIPE_WEBHOOK_SECRET="whsec_your_webhook_secret"

# URLs
BACKEND_URL="http://localhost:3002"
FRONTEND_URL="http://localhost:3000"


